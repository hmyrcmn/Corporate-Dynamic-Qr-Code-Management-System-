APP_NAME="DynamicQR Laravel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8012
APP_TIMEZONE=Europe/Istanbul

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=dynamicqr
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@dynamicqr.local"
MAIL_FROM_NAME="${APP_NAME}"

LDAP_ENABLED=false
LDAP_CONNECTION=default
LDAP_HOSTS=172.17.60.20
LDAP_PORT=389
LDAP_BASE_DN=DC=yee,DC=org,DC=tr
LDAP_DOMAIN=yee.org.tr
LDAP_NETBIOS_DOMAIN=YEE
# Optional service account. Leave both blank to bind with the submitted user credentials.
LDAP_USERNAME=
LDAP_PASSWORD=
# Default Active Directory attribute mappings.
LDAP_LOGIN_ATTRIBUTE=samaccountname
LDAP_DISPLAY_ATTRIBUTE=displayname
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_DEPARTMENT_ATTRIBUTE=department
LDAP_SSL=false
LDAP_TLS=false
LDAP_SASL=false
LDAP_TIMEOUT=5
LDAP_LOGGING=false
LDAP_CACHE=false
LDAP_ONLY_ENABLED_USERS=true
# Optional raw LDAP filter applied to all LDAP user queries.
LDAP_USER_FILTER=
# Force direct end-user bind even if service credentials are configured.
LDAP_FORCE_USER_BIND=true
# Optional username that should be promoted to SUPER_ADMIN when synced from LDAP.
LDAP_SUPER_ADMIN_USERNAME=

LOCAL_SUPER_ADMIN_ENABLED=true
LOCAL_SUPER_ADMIN_USERNAME=admin
LOCAL_SUPER_ADMIN_PASSWORD=ChangeMe123!

ALLOWED_QR_DOMAINS=yee.org.tr,gov.tr,youtube.com
IP_HASH_SALT=dynamicqr-laravel-dev-salt

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
